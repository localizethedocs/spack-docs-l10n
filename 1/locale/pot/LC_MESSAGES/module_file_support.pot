msgid "$ spack module tcl refresh"
msgstr ""

#: ../../../module_file_support.rst:31 ../../../module_file_support.rst:43
msgid "or"
msgstr ""

#: ../../../module_file_support.rst:33
msgid "$ spack module lmod refresh"
msgstr ""

#: ../../../module_file_support.rst:37
msgid ""
"Spack can also generate module files for all future installations "
"automatically through the following configuration:"
msgstr ""

#: ../../../module_file_support.rst:39
msgid "$ spack config add modules:default:enable:[tcl]"
msgstr ""

#: ../../../module_file_support.rst:45
