"                \"additionalProperties\": False,\n"
"                \"properties\": {\n"
"                    \"spec\": {\"type\": \"string\"},\n"
"                    \"message\": {\"type\": \"string\"},\n"
"                    \"when\": {\"type\": \"string\"},\n"
"                },\n"
"            },\n"
