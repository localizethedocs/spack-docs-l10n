"                    \"providers\": {\n"
"                        \"type\": \"object\",\n"
"                        \"default\": {},\n"
"                        \"additionalProperties\": {\n"
"                            \"type\": \"array\",\n"
"                            \"default\": [],\n"
"                            \"items\": {\"type\": \"string\"},\n"
"                        },\n"
"                    },\n"
"                    \"variants\": variants,\n"
"                },\n"
"                \"deprecatedProperties\": [\n"
"                    {\n"
