#: spack.util.compression.FileTypeInterface.magic_numbers:1
msgid "Return a list of all potential magic numbers for a filetype"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/compression.py:docstring of
#: spack.util.compression.FileTypeInterface.matches_magic:1
msgid ""
"Returns true if the stream matches the current file type by any of its magic "
"numbers. Resets stream to original position."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/compression.py:docstring of
#: spack.util.compression.FileTypeInterface.matches_magic:4
msgid "file byte stream"
msgstr ""

