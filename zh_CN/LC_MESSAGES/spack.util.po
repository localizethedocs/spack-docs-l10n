msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/compression.py:docstring of
#: spack.util.compression.decompressor_for:1
msgid ""
"Returns appropriate decompression/extraction algorithm function pointer for "
"provided extension. If extension is none, it is computed from the ``path`` "
"and the decompression function is derived from that information."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/compression.py:docstring of
#: spack.util.compression.decompressor_for_nix:1
msgid ""
"Returns a function pointer to appropriate decompression algorithm based on "
"extension type and unix specific considerations i.e. a reasonable "
"expectation system utils like gzip, bzip2, and xz are available"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/compression.py:docstring of
#: spack.util.compression.decompressor_for_nix:5
