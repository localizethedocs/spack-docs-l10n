msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/compression.py:docstring of
#: spack.util.compression.decompressor_for_win:1
msgid ""
"Returns a function pointer to appropriate decompression algorithm based on "
"extension type and Windows specific considerations"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/compression.py:docstring of
#: spack.util.compression.decompressor_for_win:4
msgid ""
"Windows natively vendors *only* tar, no other archive/compression utilities "
"So we must rely exclusively on Python module support for all compression "
"operations, tar for tarballs and zip files, and 7zip for Z compressed "
"archives and files as Python does not provide support for the UNIX compress "
"algorithm"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/compression.py:docstring of
#: spack.util.compression.extension_from_magic_numbers:1
msgid ""
"Return typical extension without leading ``.`` of a compressed file or "
"archive at the given path, based on its magic numbers, similar to the "
"``file`` utility. Notice that the extension returned from this function may "
"not coincide with the file's given extension."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/compression.py:docstring of
#: spack.util.compression.extension_from_magic_numbers:5
msgid "file to determine extension of"
msgstr ""

