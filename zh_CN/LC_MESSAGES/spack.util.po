#: ../../../_spack_root/lib/spack/spack/util/windows_registry.py:docstring of
#: spack.util.windows_registry.WindowsRegistryView:1
msgid ""
"Interface to provide access, querying, and searching to Windows registry "
"entries. This class represents a single key entrypoint into the Windows "
"registry and provides an interface to this key's values, its subkeys, and "
"those subkey's values. This class cannot be used to move freely about the "
"registry, only subkeys/values of the root key used to instantiate this class."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/windows_registry.py:docstring of
#: spack.util.windows_registry.WindowsRegistryView.find_matching_subkey:1
