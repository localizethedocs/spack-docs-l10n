#: ../../../_spack_root/lib/spack/spack/util/archive.py:docstring of
#: spack.util.archive.reproducible_tarfile_from_prefix:1
msgid ""
"Create a tarball from a given directory. Only adds regular files, symlinks "
"and dirs. Skips devices, fifos. Preserves hardlinks. Normalizes permissions "
"like git. Tar entries are added in depth-first pre-order, with dir entries "
"partitioned by file | dir, and sorted lexicographically, for "
"reproducibility. Partitioning ensures only one dir is in memory at a time, "
"and sorting improves compression."
msgstr ""

