#: ../../../build_systems/octavepackage.rst:13
msgid "Octave"
msgstr ""

#: ../../../build_systems/octavepackage.rst:15
msgid "Octave has its own build system for installing packages."
msgstr ""

#: ../../../build_systems/octavepackage.rst:18
msgid "Phases"
msgstr ""

#: ../../../build_systems/octavepackage.rst:20
msgid ""
"The ``OctaveBuilder`` and ``OctavePackage`` base classes have a single phase:"
msgstr ""

#: ../../../build_systems/octavepackage.rst:22
msgid "``install`` - install the package"
msgstr ""

#: ../../../build_systems/octavepackage.rst:24
msgid "By default, this phase runs the following command:"
msgstr ""

#: ../../../build_systems/octavepackage.rst:26
msgid "$ octave '--eval' 'pkg prefix <prefix>; pkg install <archive_file>'"
msgstr ""

#: ../../../build_systems/octavepackage.rst:31
msgid ""
"Beware that uninstallation is not implemented at the moment. After "
"uninstalling a package via Spack, you also need to manually uninstall it "
"from Octave via ``pkg uninstall <package_name>``."
msgstr ""

#: ../../../build_systems/octavepackage.rst:35
msgid "Finding Octave packages"
msgstr ""

#: ../../../build_systems/octavepackage.rst:37
msgid ""
"Most Octave packages are listed at https://octave.sourceforge.io/packages."
"php."
msgstr ""

#: ../../../build_systems/octavepackage.rst:40
msgid "Dependencies"
msgstr ""

#: ../../../build_systems/octavepackage.rst:42
msgid ""
"Usually, the homepage of a package will list dependencies, i.e., "
"``Dependencies: Octave >= 3.6.0 struct >= 1.0.12``. The same information "
"should be available in the ``DESCRIPTION`` file in the root of each archive."
msgstr ""

