msgid ""
"$ git clone --depth=2 https://github.com/spack/spack.git\n"
"$ cd spack/bin\n"
"$ ./spack install libelf"
msgstr ""
"$ git clone --depth=2 https://github.com/spack/spack.git\n"
"$ cd spack/bin\n"
"$ ./spack install libelf"

