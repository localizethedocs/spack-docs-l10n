#: ../../../_spack_root/lib/spack/llnl/util/lang.py:docstring of
#: llnl.util.lang.index_by:1
msgid ""
"Create a hierarchy of dictionaries by splitting the supplied set of objects "
"on unique values of the supplied functions."
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/lang.py:docstring of
#: llnl.util.lang.index_by:4
msgid ""
"Values are used as keys. For example, suppose you have four objects with "
"attributes that look like this::"
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/lang.py:docstring of
#: llnl.util.lang.index_by:7
msgid ""
"a = Spec(\"boost %gcc target=skylake\")\n"
"b = Spec(\"mrnet %intel target=zen2\")\n"
"c = Spec(\"libelf %xlc target=skylake\")\n"
"d = Spec(\"libdwarf %intel target=zen2\")\n"
"\n"
"list_of_specs = [a,b,c,d]\n"
"index1 = index_by(list_of_specs, lambda s: str(s.target),\n"
"                  lambda s: s.compiler)\n"
"index2 = index_by(list_of_specs, lambda s: s.compiler)"
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/lang.py:docstring of
#: llnl.util.lang.index_by:17
msgid ""
"``index1`` now has two levels of dicts, with lists at the leaves, like this::"
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/lang.py:docstring of
#: llnl.util.lang.index_by:20
msgid ""
"{ 'zen2'    : { 'gcc' : [a], 'xlc' : [c] },\n"
"  'skylake' : { 'intel' : [b, d] }\n"
"}"
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/lang.py:docstring of
#: llnl.util.lang.index_by:24
msgid ""
"And ``index2`` is a single level dictionary of lists that looks like this::"
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/lang.py:docstring of
#: llnl.util.lang.index_by:27
msgid ""
"{ 'gcc'    : [a],\n"
"  'intel'  : [b,d],\n"
"  'xlc'    : [c]\n"
"}"
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/lang.py:docstring of
#: llnl.util.lang.index_by:32
msgid ""
"If any elements in funcs is a string, it is treated as the name of an "
"attribute, and acts like getattr(object, name).  So shorthand for the above "
"two indexes would be::"
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/lang.py:docstring of
#: llnl.util.lang.index_by:36
msgid ""
"index1 = index_by(list_of_specs, 'arch', 'compiler')\n"
"index2 = index_by(list_of_specs, 'compiler')"
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/lang.py:docstring of
#: llnl.util.lang.index_by:39
msgid "You can also index by tuples by passing tuples::"
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/lang.py:docstring of
#: llnl.util.lang.index_by:41
msgid "index1 = index_by(list_of_specs, ('target', 'compiler'))"
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/lang.py:docstring of
#: llnl.util.lang.index_by:43
msgid "Keys in the resulting dict will look like ('gcc', 'skylake')."
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/lang.py:docstring of
#: llnl.util.lang.key_ordering:1
msgid ""
"Decorates a class with extra methods that implement rich comparison "
"operations and ``__hash__``.  The decorator assumes that the class "
"implements a function called ``_cmp_key()``.  The rich comparison operations "
"will compare objects using this key, and the ``__hash__`` function will "
"return the hash of this key."
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/lang.py:docstring of
#: llnl.util.lang.key_ordering:7
msgid ""
"If a class already has ``__eq__``, ``__ne__``, ``__lt__``, ``__le__``, "
"``__gt__``, or ``__ge__`` defined, this decorator will overwrite them."
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/lang.py:docstring of
#: llnl.util.lang.key_ordering:10
