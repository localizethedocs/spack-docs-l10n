msgstr ""

#: ../../../_spack_root/lib/spack/spack/variant.py:docstring of
#: spack.variant.prevalidate_variant_value:9
msgid "optionally restrict validation only to variants defined for this spec"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/variant.py:docstring of
#: spack.variant.prevalidate_variant_value:10
msgid ""
"if True, raise an exception if no variant definition is valid for any "
"constraint on the spec."
msgstr ""

