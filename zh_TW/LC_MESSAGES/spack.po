msgstr ""

#: ../../../_spack_root/lib/spack/spack/binary_distribution.py:docstring of
#: spack.binary_distribution.EtagIndexHandler:3
msgid ""
"This class differs from the :class:`DefaultIndexHandler` in the following "
"ways:"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/binary_distribution.py:docstring of
#: spack.binary_distribution.EtagIndexHandler:5
msgid ""
"1. It is provided with an etag value on creation, rather than an index "
"checksum value. Note that since we never start out with an etag, the default "
"fetcher must have been used initially and determined that the etag approach "
"is valid. 2. It provides this etag value in the ``If-None-Match`` request "
"header for the index manifest. 3. It checks for special exception type and "
"response code indicating the index manifest is not modified, exiting early "
"and returning ``Fresh``, if encountered. 4. If it needs to actually read the "
"manifest, it does not need to do any checks of the url scheme to determine "
"whether an etag should be included in the return value."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/binary_distribution.py:docstring of
#: spack.binary_distribution.EtagIndexHandlerV2:1
msgid ""
"Fetcher for index.json, using ETags headers as cache invalidation strategy"
msgstr ""

