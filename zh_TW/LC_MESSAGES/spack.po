#: ../../../_spack_root/lib/spack/spack/builder.py:docstring of
#: spack.builder.BaseBuilder:1
msgid ""
"An interface for builders, without any phases defined. This class is exposed "
"in the package API, so that packagers can create a single class to define :"
"meth:`setup_build_environment` and :func:`spack.phase_callbacks.run_before` "
"and :func:`spack.phase_callbacks.run_after` callbacks that can be shared "
"among different builders."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/builder.py:docstring of
#: spack.builder.BaseBuilder:6
msgid "Example:"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/builder.py:docstring of
#: spack.builder.BaseBuilder:8
msgid ""
"class AnyBuilder(BaseBuilder):\n"
"    @run_after(\"install\")\n"
"    def fixup_install(self):\n"
"        # do something after the package is installed\n"
"        pass\n"
"\n"
"    def setup_build_environment(self, env: EnvironmentModifications) -> "
"None:\n"
"        env.set(\"MY_ENV_VAR\", \"my_value\")\n"
"\n"
"\n"
"class CMakeBuilder(cmake.CMakeBuilder, AnyBuilder):\n"
"    pass\n"
"\n"
"\n"
"class AutotoolsBuilder(autotools.AutotoolsBuilder, AnyBuilder):\n"
"    pass"
msgstr ""

