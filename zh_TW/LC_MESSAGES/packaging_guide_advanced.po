#: ../../../packaging_guide_advanced.rst:28
msgid "Multiple build systems"
msgstr ""

#: ../../../packaging_guide_advanced.rst:30
msgid ""
"Packages may use different build systems over time or across platforms. "
"Spack is designed to handle this seamlessly within a single ``package.py`` "
"file."
msgstr ""

#: ../../../packaging_guide_advanced.rst:33
msgid ""
"Let's assume we work with ``curl`` and that the package is built using "
"Autotools so far:"
msgstr ""

#: ../../../packaging_guide_advanced.rst:35
msgid ""
"from spack_repo.builtin.build_systems.autotools import AutotoolsPackage\n"
"\n"
"\n"
"class Curl(AutotoolsPackage):\n"
"\n"
"    depends_on(\"zlib-api\")\n"
"\n"
"    def configure_args(self):\n"
"        return [f\"--with-zlib={self.spec['zlib-api'].prefix}\"]"
msgstr ""

#: ../../../packaging_guide_advanced.rst:47
msgid "To add CMake as a further build system we need to:"
msgstr ""

#: ../../../packaging_guide_advanced.rst:49
msgid ""
"Add another base to the ``Curl`` package class (in our case ``cmake."
"CMakePackage``),"
msgstr ""

#: ../../../packaging_guide_advanced.rst:50
msgid ""
"Explicitly declare which build systems are supported using the "
"``build_system`` directive,"
msgstr ""

#: ../../../packaging_guide_advanced.rst:51
msgid ""
"Move the :doc:`build instructions <packaging_guide_build>` in *separate "
"builder classes*."
msgstr ""

#: ../../../packaging_guide_advanced.rst:53
msgid ""
"from spack_repo.builtin.build_systems import autotools, cmake\n"
"\n"
"\n"
"class Curl(cmake.CMakePackage, autotools.AutotoolsPackage):\n"
"\n"
"    build_system(\"autotools\", \"cmake\", default=\"cmake\")\n"
"\n"
"    depends_on(\"zlib-api\")\n"
"\n"
"\n"
"class AutotoolsBuilder(autotools.AutotoolsBuilder):\n"
"    def configure_args(self):\n"
"        return [f\"--with-zlib={self.spec['zlib-api'].prefix}\"]\n"
"\n"
"\n"
"class CMakeBuilder(cmake.CMakeBuilder):\n"
"    def cmake_args(self):\n"
"        return [self.define_from_variant(\"USE_NGHTTP2\", \"nghttp2\")]"
msgstr ""

#: ../../../packaging_guide_advanced.rst:74
msgid ""
"In general, with multiple build systems there is a clear split between the :"
"doc:`package metadata <packaging_guide_creation>` and the :doc:`build "
"instructions <packaging_guide_build>`:"
msgstr ""

#: ../../../packaging_guide_advanced.rst:76
msgid ""
"The directives such as ``depends_on``, ``variant``, ``patch`` go into the "
"package class"
msgstr ""

#: ../../../packaging_guide_advanced.rst:77
msgid ""
"The build phase functions like ``configure``, ``build`` and ``install``, and "
"helper functions such as ``cmake_args`` or ``configure_args`` go into the "
"builder classes"
msgstr ""

#: ../../../packaging_guide_advanced.rst:79
msgid ""
"When ``curl`` is concretized, we can select its build system using the "
"``build_system`` variant, which is available for every package:"
msgstr ""

#: ../../../packaging_guide_advanced.rst:81
msgid "$ spack install curl build_system=cmake"
msgstr ""

#: ../../../packaging_guide_advanced.rst:86
msgid "Override \"phases\" of a build system"
msgstr ""

#: ../../../packaging_guide_advanced.rst:88
msgid ""
"Sometimes package recipes need to override entire :ref:`phases <overriding-"
"phases>` of a build system. Let's assume this happens for ``cp2k``:"
msgstr ""

#: ../../../packaging_guide_advanced.rst:91
msgid ""
"from spack.package import *\n"
"from spack_repo.builtin.build_systems import autotools\n"
"\n"
"\n"
"class Cp2k(autotools.AutotoolsPackage):\n"
"    def install(self, spec: Spec, prefix: str) -> None:\n"
"        # ...existing code...\n"
"        pass"
msgstr ""

#: ../../../packaging_guide_advanced.rst:102
msgid ""
"If we want to add CMake as another build system we need to remember that the "
"signature of phases changes when moving from the ``Package`` to the "
"``Builder`` class:"
msgstr ""

#: ../../../packaging_guide_advanced.rst:104
msgid ""
"from spack.package import *\n"
"from spack_repo.builtin.build_systems import autotools, cmake\n"
"\n"
"\n"
"class Cp2k(autotools.AutotoolsPackage, cmake.CMakePackage):\n"
"    build_system(\"autotools\", \"cmake\", default=\"cmake\")\n"
"\n"
"\n"
"class AutotoolsBuilder(autotools.AutotoolsBuilder):\n"
"    def install(self, pkg: Cp2k, spec: Spec, prefix: str) -> None:\n"
"        # ...existing code...\n"
"        pass"
msgstr ""

#: ../../../packaging_guide_advanced.rst:119
msgid ""
"The ``install`` method now takes the ``Package`` instance as the first "
"argument, since ``self`` refers to the builder class."
msgstr ""

#: ../../../packaging_guide_advanced.rst:122
msgid "Add dependencies conditional on a build system"
msgstr ""

#: ../../../packaging_guide_advanced.rst:124
msgid ""
"Many build dependencies are conditional on which build system is chosen. An "
"effective way to handle this is to use a ``with when(\"build_system=...\")`` "
"block to specify dependencies that are only relevant for a specific build "
"system:"
msgstr ""

#: ../../../packaging_guide_advanced.rst:127
msgid ""
"from spack.package import *\n"
"from spack_repo.builtin.build_systems import cmake, autotools\n"
"\n"
"\n"
"class Cp2k(cmake.CMakePackage, autotools.AutotoolsPackage):\n"
"\n"
"    build_system(\"cmake\", \"autotools\", default=\"cmake\")\n"
"\n"
"    # Runtime dependencies\n"
"    depends_on(\"ncurses\")\n"
"    depends_on(\"libxml2\")\n"
"\n"
"    # Lowerbounds for cmake only apply when using cmake as the build system\n"
"    with when(\"build_system=cmake\"):\n"
"        depends_on(\"cmake@3.18:\", when=\"@2.0:\", type=\"build\")\n"
"        depends_on(\"cmake@3:\", type=\"build\")\n"
"\n"
"    # Specify extra build dependencies used only in the configure script\n"
"    with when(\"build_system=autotools\"):\n"
"        depends_on(\"perl\", type=\"build\")\n"
"        depends_on(\"pkgconfig\", type=\"build\")"
msgstr ""

#: ../../../packaging_guide_advanced.rst:152
msgid "Transition from one build system to another"
msgstr ""

#: ../../../packaging_guide_advanced.rst:154
msgid ""
"Packages that transition from one build system to another can be modeled "
"using :ref:`conditional variant values <variant-conditional-values>`:"
msgstr ""

#: ../../../packaging_guide_advanced.rst:156
msgid ""
"from spack.package import *\n"
"from spack_repo.builtin.build_systems import cmake, autotools\n"
"\n"
"\n"
"class Cp2k(cmake.CMakePackage, autotools.AutotoolsPackage):\n"
"\n"
"    build_system(\n"
"        conditional(\"cmake\", when=\"@0.64:\"),\n"
"        conditional(\"autotools\", when=\"@:0.63\"),\n"
"        default=\"cmake\",\n"
"    )"
msgstr ""

#: ../../../packaging_guide_advanced.rst:170
msgid ""
"In the example, the directive imposes a change from ``Autotools`` to "
"``CMake`` going from ``v0.63`` to ``v0.64``."
msgstr ""

#: ../../../packaging_guide_advanced.rst:173
msgid "Inherit from a package with multiple build systems"
msgstr ""

#: ../../../packaging_guide_advanced.rst:175
msgid ""
"Customizing a package supporting multiple build systems is straightforward. "
"If we need to only customize the metadata, we can just define the derived "
"package class."
msgstr ""

#: ../../../packaging_guide_advanced.rst:178
msgid ""
"For instance, let's assume we want to add a new version to the ``silo`` "
"package:"
msgstr ""

#: ../../../packaging_guide_advanced.rst:180
msgid ""
"from spack_repo.builtin.packages.silo.package import Silo as BuiltinSilo\n"
"\n"
"class Silo(BuiltinSilo):\n"
"    # Version not in builtin.silo\n"
"    version(\"special_version\")"
msgstr ""

#: ../../../packaging_guide_advanced.rst:188
msgid ""
"If we don't define any builder, Spack will reuse the custom builder from "
"``builtin.silo`` by default. If we need to customize the builder too, we "
"just have to inherit from it, like any other Python class:"
msgstr ""

#: ../../../packaging_guide_advanced.rst:191
msgid ""
"from spack_repo.builtin.packages.silo.package import CMakeBuilder as "
"SiloCMakeBuilder\n"
"\n"
"class CMakeBuilder(SiloCMakeBuilder):\n"
"    def cmake_args(self):\n"
"        return [self.define_from_variant(\"USE_NGHTTP2\", \"nghttp2\")]"
msgstr ""

#: ../../../packaging_guide_advanced.rst:202
msgid "Making a package discoverable with ``spack external find``"
msgstr ""

#: ../../../packaging_guide_advanced.rst:204
msgid ""
"The simplest way to make a package discoverable with :ref:`spack external "
"find <cmd-spack-external-find>` is to:"
msgstr ""

#: ../../../packaging_guide_advanced.rst:206
msgid "Define the executables associated with the package."
msgstr ""

#: ../../../packaging_guide_advanced.rst:207
msgid "Implement a method to determine the versions of these executables."
msgstr ""

#: ../../../packaging_guide_advanced.rst:210
msgid "Minimal detection"
msgstr ""

#: ../../../packaging_guide_advanced.rst:212
msgid ""
"The first step is fairly simple, as it requires only to specify a package-"
"level ``executables`` attribute:"
msgstr ""

#: ../../../packaging_guide_advanced.rst:214
msgid ""
"class Foo(Package):\n"
"    # Each string provided here is treated as a regular expression, and\n"
"    # would match for example \"foo\", \"foobar\", and \"bazfoo\".\n"
"    executables = [\"foo\"]"
msgstr ""

#: ../../../packaging_guide_advanced.rst:221
msgid ""
"This attribute must be a list of strings. Each string is a regular "
"expression (e.g. \"gcc\" would match \"gcc\", \"gcc-8.3\", \"my-weird-gcc\", "
"etc.) to determine a set of system executables that might be part of this "
"package. Note that to match only executables named \"gcc\" the regular "
"expression ``\"^gcc$\"`` must be used."
msgstr ""

#: ../../../packaging_guide_advanced.rst:225
msgid ""
"Finally, to determine the version of each executable the "
"``determine_version`` method must be implemented:"
msgstr ""

#: ../../../packaging_guide_advanced.rst:227
msgid ""
"@classmethod\n"
"def determine_version(cls, exe):\n"
"    \"\"\"Return either the version of the executable passed as argument\n"
"    or ``None`` if the version cannot be determined.\n"
"\n"
"    Args:\n"
"        exe (str): absolute path to the executable being examined\n"
"    \"\"\""
msgstr ""

#: ../../../packaging_guide_advanced.rst:238
msgid ""
"This method receives as input the path to a single executable and must "
"return as output its version as a string. If the version cannot be "
"determined, or if the executable turns out to be a false positive, the value "
"``None`` must be returned, which ensures that the executable is discarded as "
"a candidate. Implementing the two steps above is mandatory, and gives the "
"package the basic ability to detect if a spec is present on the system at a "
"given version."
msgstr ""

#: ../../../packaging_guide_advanced.rst:243
msgid ""
"Any executable for which the ``determine_version`` method returns ``None`` "
"will be discarded and won't appear in later stages of the workflow described "
"below."
msgstr ""

#: ../../../packaging_guide_advanced.rst:246
msgid "Additional functionality"
msgstr ""

#: ../../../packaging_guide_advanced.rst:248
msgid ""
"Besides the two mandatory steps described above, there are also optional "
"methods that can be implemented to either increase the amount of details "
"being detected or improve the robustness of the detection logic in a package."
msgstr ""

#: ../../../packaging_guide_advanced.rst:251
msgid "Variants and custom attributes"
msgstr ""

#: ../../../packaging_guide_advanced.rst:253
msgid ""
"The ``determine_variants`` method can be optionally implemented in a package "
"to detect additional details of the spec:"
msgstr ""

#: ../../../packaging_guide_advanced.rst:255
msgid ""
"@classmethod\n"
"def determine_variants(cls, exes, version_str):\n"
"    \"\"\"Return either a variant string, a tuple of a variant string\n"
"    and a dictionary of extra attributes that will be recorded in\n"
"    packages.yaml or a list of those items.\n"
"\n"
"    Args:\n"
"        exes (list of str): list of executables (absolute paths) that\n"
"            live in the same prefix and share the same version\n"
"        version_str (str): version associated with the list of\n"
"            executables, as detected by ``determine_version``\n"
"    \"\"\""
msgstr ""

#: ../../../packaging_guide_advanced.rst:270
msgid ""
"This method takes as input a list of executables that live in the same "
"prefix and share the same version string, and returns either:"
msgstr ""

#: ../../../packaging_guide_advanced.rst:272
msgid "A variant string"
msgstr ""

#: ../../../packaging_guide_advanced.rst:273
msgid "A tuple of a variant string and a dictionary of extra attributes"
msgstr ""

#: ../../../packaging_guide_advanced.rst:274
msgid ""
"A list of items matching either 1 or 2 (if multiple specs are detected from "
"the set of executables)"
msgstr ""

#: ../../../packaging_guide_advanced.rst:276
msgid ""
"If extra attributes are returned, they will be recorded in ``packages.yaml`` "
"and be available for later reuse. As an example, the ``gcc`` package will "
"record by default the different compilers found and an entry in ``packages."
"yaml`` would look like:"
msgstr ""

#: ../../../packaging_guide_advanced.rst:279
msgid ""
"packages:\n"
"  gcc:\n"
"    externals:\n"
"    - spec: \"gcc@9.0.1 languages=c,c++,fortran\"\n"
"      prefix: /usr\n"
"      extra_attributes:\n"
"        compilers:\n"
"          c: /usr/bin/x86_64-linux-gnu-gcc-9\n"
"          c++: /usr/bin/x86_64-linux-gnu-g++-9\n"
"          fortran: /usr/bin/x86_64-linux-gnu-gfortran-9"
msgstr ""

#: ../../../packaging_guide_advanced.rst:292
msgid ""
"This allows us, for instance, to keep track of executables that would be "
"named differently if built by Spack (e.g. ``x86_64-linux-gnu-gcc-9`` instead "
"of just ``gcc``)."
msgstr ""

#: ../../../packaging_guide_advanced.rst:300
msgid "Filter matching executables"
msgstr ""

#: ../../../packaging_guide_advanced.rst:302
msgid ""
"Sometimes defining the appropriate regex for the ``executables`` attribute "
"might prove to be difficult, especially if one has to deal with corner cases "
"or exclude \"red herrings\". To help keep the regular expressions as simple "
"as possible, each package can optionally implement a "
"``filter_detected_exes`` method:"
msgstr ""

#: ../../../packaging_guide_advanced.rst:305
msgid ""
"@classmethod\n"
"def filter_detected_exes(cls, prefix, exes_in_prefix):\n"
"    \"\"\"Return a filtered list of the executables in prefix\"\"\""
msgstr ""

#: ../../../packaging_guide_advanced.rst:311
msgid ""
"which takes as input a prefix and a list of matching executables and returns "
"a filtered list of said executables."
msgstr ""

#: ../../../packaging_guide_advanced.rst:313
msgid ""
"Using this method has the advantage of allowing custom logic for filtering, "
"and does not restrict the user to regular expressions only. Consider the "
"case of detecting the GNU C++ compiler. If we try to search for executables "
"that match ``g++``, that would have the unwanted side effect of selecting "
"also ``clang++`` - which is a C++ compiler provided by another package - if "
"present on the system. Trying to select executables that contain ``g++`` but "
"not ``clang`` would be quite complicated to do using only regular "
"expressions. Employing the ``filter_detected_exes`` method it becomes:"
msgstr ""

#: ../../../packaging_guide_advanced.rst:319
msgid ""
"class Gcc(Package):\n"
"    executables = [\"g++\"]\n"
"\n"
"    @classmethod\n"
"    def filter_detected_exes(cls, prefix, exes_in_prefix):\n"
"        return [x for x in exes_in_prefix if \"clang\" not in x]"
msgstr ""

#: ../../../packaging_guide_advanced.rst:328
msgid ""
"Another possibility that this method opens is to apply certain filtering "
"logic when specific conditions are met (e.g. take some decisions on an OS "
"and not on another)."
msgstr ""

#: ../../../packaging_guide_advanced.rst:331
msgid "Validate detection"
msgstr ""

#: ../../../packaging_guide_advanced.rst:333
msgid ""
"To increase detection robustness, packagers may also implement a method to "
"validate the detected Spec objects:"
msgstr ""

#: ../../../packaging_guide_advanced.rst:335
msgid ""
"@classmethod\n"
"def validate_detected_spec(cls, spec, extra_attributes):\n"
"    \"\"\"Validate a detected spec. Raise an exception if validation fails."
"\"\"\""
msgstr ""

#: ../../../packaging_guide_advanced.rst:341
msgid ""
"This method receives a detected spec along with its extra attributes and can "
"be used to check that certain conditions are met by the spec. Packagers can "
"either use assertions or raise an ``InvalidSpecDetected`` exception when the "
"check fails. If the conditions are not honored the spec will be discarded "
"and any message associated with the assertion or the exception will be "
"logged as the reason for discarding it."
msgstr ""

#: ../../../packaging_guide_advanced.rst:345
msgid ""
"As an example, a package that wants to check that the ``compilers`` "
"attribute is in the extra attributes can implement this method like this:"
msgstr ""

#: ../../../packaging_guide_advanced.rst:347
msgid ""
"@classmethod\n"
"def validate_detected_spec(cls, spec, extra_attributes):\n"
"    \"\"\"Check that \"compilers\" is in the extra attributes.\"\"\"\n"
"    msg = \"the extra attribute 'compilers' must be set for the detected "
"spec '{0}'\".format(spec)\n"
"    assert \"compilers\" in extra_attributes, msg"
msgstr ""

#: ../../../packaging_guide_advanced.rst:355
msgid "or like this:"
msgstr ""

#: ../../../packaging_guide_advanced.rst:357
msgid ""
"@classmethod\n"
"def validate_detected_spec(cls, spec, extra_attributes):\n"
"    \"\"\"Check that \"compilers\" is in the extra attributes.\"\"\"\n"
"    if \"compilers\" not in extra_attributes:\n"
"        msg = \"the extra attribute 'compilers' must be set for the detected "
"spec '{0}'\".format(\n"
"            spec\n"
"        )\n"
"        raise InvalidSpecDetected(msg)"
msgstr ""

#: ../../../packaging_guide_advanced.rst:371
msgid "Custom detection workflow"
msgstr ""

#: ../../../packaging_guide_advanced.rst:373
msgid ""
"In the rare case when the mechanisms described so far don't fit the "
"detection of a package, the implementation of all the methods above can be "
"disregarded and instead a custom ``determine_spec_details`` method can be "
"implemented directly in the package class (note that the definition of the "
"``executables`` attribute is still required):"
msgstr ""

#: ../../../packaging_guide_advanced.rst:375
msgid ""
"@classmethod\n"
"def determine_spec_details(cls, prefix, exes_in_prefix):\n"
"    # exes_in_prefix = a set of paths, each path is an executable\n"
"    # prefix = a prefix that is common to each path in exes_in_prefix\n"
"\n"
"    # return None or [] if none of the exes represent an instance of\n"
"    # the package. Return one or more Specs for each instance of the\n"
"    # package which is thought to be installed in the provided prefix\n"
"    ..."
msgstr ""

#: ../../../packaging_guide_advanced.rst:387
msgid ""
"This method takes as input a set of discovered executables (which match "
"those specified by the user) as well as a common prefix shared by all of "
"those executables. The function must return one or more :py:class:`spack."
"package.Spec` associated with the executables (it can also return ``None`` "
"to indicate that no provided executables are associated with the package)."
msgstr ""

#: ../../../packaging_guide_advanced.rst:390
msgid ""
"As an example, consider a made-up package called ``foo-package`` which "
"builds an executable called ``foo``. ``FooPackage`` would appear as follows:"
msgstr ""

#: ../../../packaging_guide_advanced.rst:393
msgid ""
"class FooPackage(Package):\n"
"    homepage = \"...\"\n"
"    url = \"...\"\n"
"\n"
"    version(...)\n"
"\n"
"    # Each string provided here is treated as a regular expression, and\n"
"    # would match for example \"foo\", \"foobar\", and \"bazfoo\".\n"
"    executables = [\"foo\"]\n"
"\n"
"    @classmethod\n"
"    def determine_spec_details(cls, prefix, exes_in_prefix):\n"
"        candidates = [x for x in exes_in_prefix if os.path.basename(x) == "
"\"foo\"]\n"
"        if not candidates:\n"
"            return\n"
"        # This implementation is lazy and only checks the first candidate\n"
"        exe_path = candidates[0]\n"
"        exe = Executable(exe_path)\n"
"        output = exe(\"--version\", output=str, error=str)\n"
"        version_str = ...  # parse output for version string\n"
"        return Spec.from_detection(\"foo-package@{0}\".format(version_str))"
msgstr ""

#: ../../../packaging_guide_advanced.rst:418
msgid "Add detection tests to packages"
msgstr ""

#: ../../../packaging_guide_advanced.rst:420
msgid ""
"To ensure that software is detected correctly for multiple configurations "
"and on different systems users can write a ``detection_test.yaml`` file and "
"put it in the package directory alongside the ``package.py`` file. This YAML "
"file contains enough information for Spack to mock an environment and try to "
"check if the detection logic yields the results that are expected."
msgstr ""

#: ../../../packaging_guide_advanced.rst:423
msgid ""
"As a general rule, attributes at the top-level of ``detection_test.yaml`` "
"represent search mechanisms and they each map to a list of tests that should "
"confirm the validity of the package's detection logic."
msgstr ""

#: ../../../packaging_guide_advanced.rst:425
msgid "The detection tests can be run with the following command:"
msgstr ""

#: ../../../packaging_guide_advanced.rst:427
msgid "$ spack audit externals"
msgstr ""

#: ../../../packaging_guide_advanced.rst:431
msgid "Errors that have been detected are reported to screen."
msgstr ""

#: ../../../packaging_guide_advanced.rst:434
msgid "Tests for PATH inspections"
msgstr ""

#: ../../../packaging_guide_advanced.rst:436
msgid ""
"Detection tests insisting on ``PATH`` inspections are listed under the "
"``paths`` attribute:"
msgstr ""

#: ../../../packaging_guide_advanced.rst:438
