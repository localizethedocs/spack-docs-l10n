#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.index_by:1
msgid ""
"Create a hierarchy of dictionaries by splitting the supplied set of objects "
"on unique values of the supplied functions."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.index_by:4
msgid ""
"Values are used as keys. For example, suppose you have four objects with "
"attributes that look like this::"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.index_by:7
msgid ""
"a = Spec(\"boost %gcc target=skylake\")\n"
"b = Spec(\"mrnet %intel target=zen2\")\n"
"c = Spec(\"libelf %xlc target=skylake\")\n"
"d = Spec(\"libdwarf %intel target=zen2\")\n"
"\n"
"list_of_specs = [a,b,c,d]\n"
"index1 = index_by(list_of_specs, lambda s: str(s.target),\n"
"                  lambda s: s.compiler)\n"
"index2 = index_by(list_of_specs, lambda s: s.compiler)"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.index_by:17
msgid ""
"``index1`` now has two levels of dicts, with lists at the leaves, like this::"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.index_by:20
msgid ""
"{ 'zen2'    : { 'gcc' : [a], 'xlc' : [c] },\n"
"  'skylake' : { 'intel' : [b, d] }\n"
"}"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.index_by:24
msgid ""
"And ``index2`` is a single level dictionary of lists that looks like this::"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.index_by:27
msgid ""
"{ 'gcc'    : [a],\n"
"  'intel'  : [b,d],\n"
"  'xlc'    : [c]\n"
"}"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.index_by:32
msgid ""
"If any elements in funcs is a string, it is treated as the name of an "
"attribute, and acts like ``getattr(object, name)``.  So shorthand for the "
"above two indexes would be::"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.index_by:36
msgid ""
"index1 = index_by(list_of_specs, 'arch', 'compiler')\n"
"index2 = index_by(list_of_specs, 'compiler')"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.index_by:39
msgid "You can also index by tuples by passing tuples::"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.index_by:41
msgid "index1 = index_by(list_of_specs, ('target', 'compiler'))"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.index_by:43
msgid "Keys in the resulting dict will look like ``('gcc', 'skylake')``."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.key_ordering:1
msgid ""
"Decorates a class with extra methods that implement rich comparison "
"operations and ``__hash__``.  The decorator assumes that the class "
"implements a function called ``_cmp_key()``.  The rich comparison operations "
"will compare objects using this key, and the ``__hash__`` function will "
"return the hash of this key."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.key_ordering:7
msgid ""
"If a class already has ``__eq__``, ``__ne__``, ``__lt__``, ``__le__``, "
"``__gt__``, or ``__ge__`` defined, this decorator will overwrite them."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.key_ordering:10
msgid "If the class does not have a ``_cmp_key`` method"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.lazy_eq:1
msgid "Equality comparison for two lazily generated sequences."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.lazy_eq:3 spack.llnl.util.lang.lazy_lt:3
msgid "See ``lazy_lexicographic_ordering``."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.lazy_lexicographic_ordering:1
msgid "Decorates a class with extra methods that implement rich comparison."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.lazy_lexicographic_ordering:3
msgid ""
"This is a lazy version of the tuple comparison used frequently to implement "
"comparison in Python. Given some objects with fields, you might use tuple "
"keys to implement comparison, e.g.:"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.lazy_lexicographic_ordering:7
msgid ""
"class Widget:\n"
"    def _cmp_key(self):\n"
"        return (self.a, self.b, (self.c, self.d), self.e)\n"
"\n"
"    def __eq__(self, other):\n"
"        return self._cmp_key() == other._cmp_key()\n"
"\n"
"    def __lt__(self):\n"
"        return self._cmp_key() < other._cmp_key()\n"
"\n"
"    # etc."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.lazy_lexicographic_ordering:21
msgid ""
"Python would compare ``Widgets`` lexicographically based on their tuples. "
"The issue there for simple comparators is that we have to build the tuples "
"*and* we have to generate all the values in them up front. When implementing "
"comparisons for large data structures, this can be costly."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.lazy_lexicographic_ordering:27
msgid ""
"Lazy lexicographic comparison maps the tuple comparison shown above to "
"generator functions. Instead of comparing based on pre-constructed tuple "
"keys, users of this decorator can compare using elements from a generator. "
"So, you'd write:"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.lazy_lexicographic_ordering:32
msgid ""
"@lazy_lexicographic_ordering\n"
"class Widget:\n"
"    def _cmp_iter(self):\n"
"        yield a\n"
"        yield b\n"
"        def cd_fun():\n"
"            yield c\n"
"            yield d\n"
"        yield cd_fun\n"
"        yield e\n"
"\n"
"    # operators are added by decorator"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.lazy_lexicographic_ordering:47
msgid ""
"There are no tuples preconstructed, and the generator does not have to "
"complete. Instead of tuples, we simply make functions that lazily yield what "
"would've been in the tuple. The ``@lazy_lexicographic_ordering`` decorator "
"handles the details of implementing comparison operators, and the ``Widget`` "
"implementor only has to worry about writing ``_cmp_iter``, and making sure "
"the elements in it are also comparable."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.lazy_lexicographic_ordering:55
msgid ""
"In some cases, you may have a fast way to determine whether two objects are "
"equal, e.g. the ``is`` function or an already-computed cryptographic hash. "
"For this, you can implement your own ``_cmp_fast_eq`` function:"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.lazy_lexicographic_ordering:60
msgid ""
"@lazy_lexicographic_ordering\n"
"class Widget:\n"
"    def _cmp_iter(self):\n"
"        yield a\n"
"        yield b\n"
"\n"
"        def cd_fun():\n"
"            yield c\n"
"            yield d\n"
"\n"
"        yield cd_fun\n"
"        yield e\n"
"\n"
"    def _cmp_fast_eq(self, other):\n"
"        return self is other or None"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.lazy_lexicographic_ordering:78
msgid "``_cmp_fast_eq`` should return:"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.lazy_lexicographic_ordering:80
msgid "``True`` if ``self`` is equal to ``other``,"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.lazy_lexicographic_ordering:81
msgid "``False`` if ``self`` is not equal to ``other``, and"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.lazy_lexicographic_ordering:82
msgid ""
"``None`` if it's not known whether they are equal, and the full comparison "
"should be done."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.lazy_lexicographic_ordering:85
msgid ""
"``lazy_lexicographic_ordering`` uses ``_cmp_fast_eq`` to short-circuit the "
"comparison if the answer can be determined quickly. If you do not implement "
"it, it defaults to ``self is other or None``."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.lazy_lexicographic_ordering:89
msgid "Some things to note:"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.lazy_lexicographic_ordering:91
msgid ""
"If a class already has ``__eq__``, ``__ne__``, ``__lt__``, ``__le__``, "
"``__gt__``, ``__ge__``, or ``__hash__`` defined, this decorator will "
"overwrite them."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.lazy_lexicographic_ordering:95
msgid "If ``set_hash`` is ``False``, this will not overwrite ``__hash__``."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.lazy_lexicographic_ordering:98
msgid ""
"This class uses Python 2 None-comparison semantics. If you yield None and it "
"is compared to a non-None type, None will always be less than the other "
"object."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.lazy_lexicographic_ordering:102
msgid "If the class does not have a ``_cmp_iter`` method"
msgstr ""

