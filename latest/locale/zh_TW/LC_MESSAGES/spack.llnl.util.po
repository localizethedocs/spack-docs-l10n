"This works like the command-line ``uniq`` tool.  It filters strings of "
"duplicate elements in a list. Adjacent matching elements are merged into the "
"first occurrence."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.uniq:7
msgid "For example::"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lang.py:docstring of
#: spack.llnl.util.lang.uniq:9
msgid ""
"uniq([1, 1, 1, 1, 2, 2, 2, 3, 3]) == [1, 2, 3]\n"
"uniq([1, 1, 1, 1, 2, 2, 2, 1, 1]) == [1, 2, 1]"
msgstr ""

#: ../../../spack.llnl.util.rst:45
msgid "spack.llnl.util.link\\_tree module"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/link_tree.py:docstring of
#: spack.llnl.util.link_tree:1
msgid "LinkTree class for setting up trees of symbolic links."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/link_tree.py:docstring of
#: spack.llnl.util.link_tree.LinkTree:1
msgid "Class to create trees of symbolic links from a source directory."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/link_tree.py:docstring of
#: spack.llnl.util.link_tree.LinkTree:3
msgid ""
"LinkTree objects are constructed with a source root.  Their methods allow "
"you to create and delete trees of symbolic links back to the source tree in "
"specific destination directories. Trees comprise symlinks only to files; "
"directories are never symlinked to, to prevent the source directory from "
"ever being modified."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/link_tree.py:docstring of
#: spack.llnl.util.link_tree.LinkTree.find_conflict:1
msgid "Returns the first file in dest that conflicts with src"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/link_tree.py:docstring of
#: spack.llnl.util.link_tree.LinkTree.merge:1
msgid "Link all files in src into dest, creating directories if necessary."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/link_tree.py:docstring of
#: spack.llnl.util.link_tree.LinkTree.merge:3
msgid ""
"if True, do not break when the target exists; return a list of files that "
"could not be linked"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/link_tree.py:docstring of
#: spack.llnl.util.link_tree.LinkTree.merge:5
msgid ""
"callable that returns True if a file is to be ignored in the merge (by "
"default ignore nothing)"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/link_tree.py:docstring of
#: spack.llnl.util.link_tree.LinkTree.merge:7
msgid ""
"function to create links with (defaults to ``spack.llnl.util.filesystem."
"symlink``)"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/link_tree.py:docstring of
#: spack.llnl.util.link_tree.LinkTree.merge:9
msgid "create all symlinks relative to the target (default False)"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/link_tree.py:docstring of
#: spack.llnl.util.link_tree.LinkTree.unmerge:1
msgid "Unlink all files in dest that exist in src."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/link_tree.py:docstring of
#: spack.llnl.util.link_tree.LinkTree.unmerge:3
msgid "Unlinks directories in dest if they are empty."
msgstr ""

#: ../../../spack.llnl.util.rst:53
msgid "spack.llnl.util.lock module"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.CantCreateLockError:1
msgid "Attempt to create a lock in an unwritable location."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.Lock:1
msgid "This is an implementation of a filesystem lock using Python's lockf."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.Lock:3
msgid ""
"In Python, ``lockf`` actually calls ``fcntl``, so this should work with any "
"filesystem implementation that supports locking through the fcntl calls. "
"This includes distributed filesystems like Lustre (when flock is enabled) "
"and recent NFS versions."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.Lock:7
msgid ""
"Note that this is for managing contention over resources *between* processes "
"and not for managing contention between threads in a process: the functions "
"of this object are not thread-safe. A process also must not maintain "
"multiple locks on the same file (or, more specifically, on overlapping byte "
"ranges in the same file)."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.Lock.acquire_read:1
msgid "Acquires a recursive, shared lock for reading."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.Lock.acquire_read:3
#: spack.llnl.util.lock.Lock.acquire_write:3
msgid ""
"Read and write locks can be acquired and released in arbitrary order, but "
"the POSIX lock is held until all local read and write locks are released."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.Lock.acquire_read:6
#: spack.llnl.util.lock.Lock.acquire_write:6
msgid ""
"Returns True if it is the first acquire and actually acquires the POSIX "
"lock, False if it is a nested transaction."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.Lock.acquire_write:1
msgid "Acquires a recursive, exclusive lock for writing."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.Lock.downgrade_write_to_read:1
msgid "Downgrade from an exclusive write lock to a shared read."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.Lock.downgrade_write_to_read:3
#: spack.llnl.util.lock.Lock.upgrade_read_to_write:3
msgid "if this is an attempt at a nested transaction"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.Lock.is_write_locked:1
msgid "Returns ``True`` if the path is write locked, otherwise, ``False``"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.Lock.release_read:1
msgid "Releases a read lock."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.Lock.release_read:3
msgid ""
"function to call *before* the last recursive lock (read or write) is "
"released."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.Lock.release_read:6
msgid ""
"If the last recursive lock will be released, then this will call release_fn "
"and return its result (if provided), or return True (if release_fn was not "
"provided)."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.Lock.release_read:9
msgid ""
"Otherwise, we are still nested inside some other lock, so do not call the "
"release_fn and, return False."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.Lock.release_read:12
#: spack.llnl.util.lock.Lock.release_write:10
msgid ""
"Does limited correctness checking: if a read lock is released when none are "
"held, this will raise an assertion error."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.Lock.release_write:1
msgid "Releases a write lock."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.Lock.release_write:3
msgid "function to call before the last recursive write is released."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.Lock.release_write:5
msgid ""
"If the last recursive *write* lock will be released, then this will call "
"release_fn and return its result (if provided), or return True (if "
"release_fn was not provided). Otherwise, we are still nested inside some "
"other write lock, so do not call the release_fn, and return False."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.Lock.try_acquire_read:1
msgid "Non-blocking attempt to acquire a shared read lock."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.Lock.try_acquire_read:3
#: spack.llnl.util.lock.Lock.try_acquire_write:3
msgid "Returns True if the lock was acquired, False if it would block."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.Lock.try_acquire_write:1
msgid "Non-blocking attempt to acquire an exclusive write lock."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.Lock.upgrade_read_to_write:1
msgid "Attempts to upgrade from a shared read lock to an exclusive write."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.LockDowngradeError:1
msgid "Raised when unable to downgrade from a write to a read lock."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.LockError:1
msgid "Raised for any errors related to locks."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.LockPermissionError:1
msgid "Raised when there are permission issues with a lock."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.LockROFileError:1
msgid "Tried to take an exclusive lock on a read-only file."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.LockTimeoutError:1
msgid "Raised when an attempt to acquire a lock times out."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.LockTransaction:1
msgid "Simple nested transaction context manager that uses a file lock."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.LockTransaction:3
msgid ""
"underlying lock for this transaction to be acquired on enter and released on "
"exit"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.LockTransaction:4
msgid "function to be called after lock is acquired"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.LockTransaction:5
msgid ""
"function to be called before release, with ``(exc_type, exc_value, "
"traceback)``"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.LockTransaction:6
msgid ""
"number of seconds to set for the timeout when acquiring the lock (default no "
"timeout)"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.LockUpgradeError:1
msgid "Raised when unable to upgrade from a read to a write lock."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.ReadTransaction:1
msgid "LockTransaction context manager that does a read and releases it."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/llnl/util/lock.py:docstring of
#: spack.llnl.util.lock.WriteTransaction:1
msgid "LockTransaction context manager that does a write and releases it."
msgstr ""

