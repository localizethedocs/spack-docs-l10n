#: ../../../_spack_root/lib/spack/spack/hooks/sbang.py:docstring of
#: spack.hooks.sbang.filter_shebang:1
msgid ""
"Adds a second shebang line, using sbang, at the beginning of a file, if "
"necessary. Note: Spack imposes a relaxed shebang line limit, meaning that a "
"newline or end of file must occur before ``spack_shebang_limit`` bytes. If "
"not, the file is not patched."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/hooks/sbang.py:docstring of
#: spack.hooks.sbang.post_install:1
msgid ""
"This hook edits scripts so that they call /bin/bash $spack_prefix/bin/sbang "
"instead of something longer than the shebang limit."
msgstr ""

