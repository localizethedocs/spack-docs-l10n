#: ../../../_spack_root/lib/spack/spack/ci/__init__.py:docstring of
#: spack.ci.get_spec_filter_list:1
msgid ""
"Given a list of package names and an active/concretized environment, return "
"the set of all concrete specs from the environment that could have been "
"affected by changing the list of packages."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/ci/__init__.py:docstring of
#: spack.ci.get_spec_filter_list:5
msgid ""
"If a ``dependent_traverse_depth`` is given, it is used to limit upward (in "
"the parent direction) traversal of specs of touched packages. E.g. if 1 is "
"provided, then only direct dependents of touched package specs are traversed "
"to produce specs that could have been affected by changing the package, "
"while if 0 is provided, only the changed specs themselves are traversed. If "
"``None`` is given, upward traversal of touched package specs is done all the "
"way to the environment roots. Providing a negative number results in no "
"traversals at all, yielding an empty set."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/ci/__init__.py:docstring of
#: spack.ci.get_spec_filter_list:13
msgid "Active concrete environment"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/ci/__init__.py:docstring of
#: spack.ci.get_spec_filter_list:14
msgid "Affected package names"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/ci/__init__.py:docstring of
#: spack.ci.get_spec_filter_list:15
msgid "Integer to limit dependent traversal, None means no limit"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/ci/__init__.py:docstring of
#: spack.ci.get_spec_filter_list:17
msgid ""
