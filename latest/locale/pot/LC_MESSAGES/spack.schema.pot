"        \"versions\": {\n"
"            \"type\": \"array\",\n"
"            \"items\": {\"type\": \"string\"},\n"
"            \"description\": \"Abstract version (e.g. @1.2)\",\n"
"        },\n"
"        \"propagate\": {\n"
"            \"type\": \"array\",\n"
"            \"items\": {\"type\": \"string\"},\n"
"            \"description\": \"List of variants to propagate (for abstract "
