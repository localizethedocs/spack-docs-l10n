"}\n"
"\n"
"#: Full schema with metadata\n"
"schema = {\n"
"    \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n"
"    \"title\": \"Spack merged configuration file schema\",\n"
"    \"type\": \"object\",\n"
"    \"additionalProperties\": False,\n"
"    \"properties\": ref_sections,\n"
"    \"definitions\": defs,\n"
"}\n"
