"            },\n"
"            \"checksum\": {\n"
"                \"type\": \"boolean\",\n"
"                \"description\": \"When true, Spack verifies downloaded "
"source code using checksums\",\n"
"            },\n"
"            \"deprecated\": {\n"
"                \"type\": \"boolean\",\n"
"                \"description\": \"If true, Spack will fetch deprecated "
