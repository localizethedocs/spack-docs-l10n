"            },\n"
"            \"extensions\": {\n"
"                \"type\": \"array\",\n"
"                \"items\": {\"type\": \"string\"},\n"
"                \"description\": \"List of Spack extensions to load\",\n"
"            },\n"
"            \"template_dirs\": {\n"
"                \"type\": \"array\",\n"
"                \"items\": {\"type\": \"string\"},\n"
"                \"description\": \"Locations where templates should be "
"found\",\n"
"            },\n"
"            \"license_dir\": {\n"
"                \"type\": \"string\",\n"
"                \"description\": \"Directory where licenses should be "
