"spec_node = {\n"
"    \"type\": \"object\",\n"
"    \"additionalProperties\": False,\n"
"    \"required\": [\"name\"],\n"
"    \"properties\": {\n"
"        \"name\": {\n"
"            \"type\": [\"string\", \"null\"],\n"
