"        \"package_hash\": {\"type\": \"string\", \"description\": \"The "
"package hash (concrete specs)\"},\n"
"        \"full_hash\": {\n"
"            \"type\": \"string\",\n"
"            \"description\": \"This hash was used on some specs prior to "
