"                \"make -j), defaults to 16\",\n"
"            },\n"
"            \"concurrent_packages\": {\n"
"                \"type\": \"integer\",\n"
"                \"minimum\": 0,\n"
"                \"description\": \"The maximum number of concurrent package "
