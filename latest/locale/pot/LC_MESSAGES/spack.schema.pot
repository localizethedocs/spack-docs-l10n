"                \"conflicts (strongly recommended)\",\n"
"            },\n"
"            \"dirty\": {\n"
"                \"type\": \"boolean\",\n"
"                \"description\": \"When true, builds will NOT clean "
"potentially harmful variables \"\n"
"                \"from the environment\",\n"
"            },\n"
"            \"build_language\": {\n"
"                \"type\": \"string\",\n"
"                \"description\": \"The language the build environment will "
