#: ../../../_spack_root/lib/spack/spack/schema/spec.py:docstring of
#: spack.schema.spec:3
msgid ""
"    \"oneOf\": [\n"
"        {\n"
"            \"type\": \"string\",\n"
"            \"description\": 'Target as a string (e.g. \"zen2\" or \"haswell:"
"broadwell\") used in '\n"
"            \"abstract specs\",\n"
"        },\n"
"        {\n"
"            \"type\": \"object\",\n"
"            \"additionalProperties\": False,\n"
"            \"required\": [\"name\", \"vendor\", \"features\", "
"\"generation\", \"parents\"],\n"
"            \"properties\": {\n"
"                \"name\": {\"type\": \"string\"},\n"
"                \"vendor\": {\"type\": \"string\"},\n"
"                \"features\": {\"type\": \"array\", \"items\": {\"type\": "
"\"string\"}},\n"
"                \"generation\": {\"type\": \"integer\"},\n"
"                \"parents\": {\"type\": \"array\", \"items\": {\"type\": "
"\"string\"}},\n"
"                \"cpupart\": {\"type\": \"string\"},\n"
"            },\n"
"            \"description\": \"Target as an object with detailed fields, "
