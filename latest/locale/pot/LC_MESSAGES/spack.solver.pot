#: ../../../_spack_root/lib/spack/spack/solver/compat.py:docstring of
#: spack.solver.compat.ClingoFlavor:3
msgid ""
"Spack supports three: the legacy pre-CFFI API, the CFFI-based API (clingo "
"``@5.5:5``), and the clingo 6 rewrite, which restructured everything into "
"submodules ``clingo.*``."
msgstr ""

