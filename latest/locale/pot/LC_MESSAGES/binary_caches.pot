msgstr ""

#: ../../../binary_caches.rst:550
msgid "``spack buildcache install``"
msgstr ""

#: ../../../binary_caches.rst:552
msgid ""
"Retrieves all specs for build caches available on a Spack mirror and "
"installs build caches with specs matching the input specs."
msgstr ""

#: ../../../binary_caches.rst:557
msgid ""
"list of partial package specs or hashes with a leading ``/`` to be installed "
"from build caches"
msgstr ""

#: ../../../binary_caches.rst:558
msgid "remove install directory if it exists before unpacking tarball"
msgstr ""

#: ../../../binary_caches.rst:559
msgid "answer yes to all to don't verify package with gpg questions"
msgstr ""

#: ../../../binary_caches.rst:563
msgid "``spack buildcache keys``"
msgstr ""

#: ../../../binary_caches.rst:565
msgid "List public keys available on a Spack mirror."
msgstr ""

#: ../../../binary_caches.rst:570
msgid "``-it``"
msgstr ""

#: ../../../binary_caches.rst:570
msgid "trust the keys downloaded with prompt for each"
msgstr ""

#: ../../../binary_caches.rst:571
