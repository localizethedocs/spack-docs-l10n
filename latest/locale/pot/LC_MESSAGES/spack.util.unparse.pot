msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/unparse/unparser.py:docstring of
#: spack.util.unparse.unparser:1
msgid "Usage: unparse.py <path to source file>"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/unparse/unparser.py:docstring of
#: spack.util.unparse.unparser.NodeVisitor:1
msgid ""
"A node visitor base class that walks the abstract syntax tree and calls a "
"visitor function for every node found.  This function may return a value "
"which is forwarded by the `visit` method."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/unparse/unparser.py:docstring of
#: spack.util.unparse.unparser.NodeVisitor:5
msgid ""
"This class is meant to be subclassed, with the subclass adding visitor "
"methods."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/unparse/unparser.py:docstring of
#: spack.util.unparse.unparser.NodeVisitor:8
msgid ""
"Per default the visitor functions for the nodes are ``'visit_'`` + class "
"name of the node.  So a `TryFinally` node visit function would be "
"`visit_TryFinally`.  This behavior can be changed by overriding the `visit` "
"method.  If no visitor function exists for a node (return value `None`) the "
"`generic_visit` visitor is used instead."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/unparse/unparser.py:docstring of
#: spack.util.unparse.unparser.NodeVisitor:14
msgid ""
"Don't use the `NodeVisitor` if you want to apply changes to nodes during "
"traversing.  For this a special visitor exists (`NodeTransformer`) that "
"allows modifications."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/unparse/unparser.py:docstring of
#: spack.util.unparse.unparser.NodeVisitor.generic_visit:1
msgid "Called if no explicit visitor function exists for a node."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/unparse/unparser.py:docstring of
#: spack.util.unparse.unparser.NodeVisitor.visit:1
msgid "Visit a node."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/unparse/unparser.py:docstring of
#: spack.util.unparse.unparser.Unparser:1
msgid ""
"Methods in this class recursively traverse an AST and output source code for "
"the abstract syntax; original formatting is disregarded."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/unparse/unparser.py:docstring of
#: spack.util.unparse.unparser.Unparser.block:1
msgid ""
"A context manager for preparing the source for blocks. It adds the "
"character':', increases the indentation on enter and decreases the "
"indentation on exit. If *extra* is given, it will be directly appended after "
"the colon character."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/unparse/unparser.py:docstring of
#: spack.util.unparse.unparser.Unparser.delimit:1
msgid ""
"A context manager for preparing the source for expressions. It adds *start* "
"to the buffer and enters, after exit it adds *end*."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/unparse/unparser.py:docstring of
#: spack.util.unparse.unparser.Unparser.fill:1
msgid ""
"Indent a piece of text and append it, according to the current indentation "
"level"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/unparse/unparser.py:docstring of
#: spack.util.unparse.unparser.Unparser.get_raw_docstring:1
msgid ""
"If a docstring node is found in the body of the *node* parameter, return "
"that docstring node, None otherwise."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/unparse/unparser.py:docstring of
#: spack.util.unparse.unparser.Unparser.get_raw_docstring:4
msgid "Logic mirrored from ``_PyAST_GetDocString``."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/unparse/unparser.py:docstring of
#: spack.util.unparse.unparser.Unparser.interleave:1
msgid "Call f on each item in seq, calling inter() in between."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/unparse/unparser.py:docstring of
#: spack.util.unparse.unparser.Unparser.items_view:1
msgid ""
"Traverse and separate the given *items* with a comma and append it to the "
"buffer. If *items* is a single item sequence, a trailing comma will be added."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/unparse/unparser.py:docstring of
#: spack.util.unparse.unparser.Unparser.maybe_newline:1
msgid "Adds a newline if it isn't the start of generated source"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/unparse/unparser.py:docstring of
#: spack.util.unparse.unparser.Unparser.require_parens:1
msgid "Shortcut to adding precedence related parens"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/unparse/unparser.py:docstring of
#: spack.util.unparse.unparser.Unparser.visit:1
msgid ""
"Outputs a source code string that, if converted back to an ast (using ast."
"parse) will generate an AST equivalent to *node*"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/unparse/unparser.py:docstring of
#: spack.util.unparse.unparser.Unparser.write:1
msgid "Add new source parts"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/unparse/unparser.py:docstring of
#: spack.util.unparse.unparser.is_non_empty_non_star_tuple:1
msgid "True for `(1, 2)`, False for `()` and `(1, *b)`"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/util/unparse/unparser.py:docstring of
#: spack.util.unparse.unparser.iter_fields:1
msgid ""
"Yield a tuple of ``(fieldname, value)`` for each field in ``node._fields`` "
"that is present on *node*."
msgstr ""
