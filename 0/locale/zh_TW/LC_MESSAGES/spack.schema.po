"                \"oneOf\": [{\"type\": \"string\"}, {\"type\": \"array\", "
"\"items\": {\"type\": \"string\"}}]\n"
"            },\n"
"            \"stage_name\": {\"type\": \"string\"},\n"
"            \"develop_stage_link\": {\"type\": \"string\"},\n"
