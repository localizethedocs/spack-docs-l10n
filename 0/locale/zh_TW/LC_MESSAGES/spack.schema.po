"                        \"flags\": flags,\n"
"                        \"spec\": {\"type\": \"string\"},\n"
"                        \"operating_system\": {\"type\": \"string\"},\n"
"                        \"target\": {\"type\": \"string\"},\n"
"                        \"alias\": {\"anyOf\": [{\"type\": \"string\"}, "
"{\"type\": \"null\"}]},\n"
"                        \"modules\": {\n"
