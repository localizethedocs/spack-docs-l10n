"                                {\"type\": \"null\"},\n"
"                                {\"type\": \"array\", \"items\": {\"type\": "
"\"string\"}},\n"
"                            ]\n"
"                        },\n"
"                        \"implicit_rpaths\": implicit_rpaths,\n"
"                        \"environment\": spack.schema.environment."
"definition,\n"
"                        \"extra_rpaths\": extra_rpaths,\n"
"                    },\n"
