"def configure_args(self):\n"
"     args = [\"--enable-cxx\"] + self.enable_or_disable(\"libs\")\n"
"     if self.spec.satisfies(\"libs=static\"):\n"
"         args.append(\"--with-pic\")\n"
"     return args"
msgstr ""

