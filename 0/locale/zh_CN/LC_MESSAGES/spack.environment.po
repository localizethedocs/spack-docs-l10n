#: spack.environment:293
msgid ""
"{\n"
"    \"_meta\": {\n"
"        \"file-type\": \"spack-lockfile\",\n"
"        \"lockfile-version\": 4,\n"
"        \"specfile-version\": 3\n"
"    },\n"
"    \"roots\": [\n"
"        {\n"
"            \"hash\": \"<dag_hash 1>\",\n"
"            \"spec\": \"<abstract spec 1>\"\n"
"        },\n"
"        {\n"
"            \"hash\": \"<dag_hash 2>\",\n"
"            \"spec\": \"<abstract spec 2>\"\n"
"        }\n"
"    ],\n"
