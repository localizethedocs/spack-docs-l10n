#: ../../../_spack_root/lib/spack/spack/environment/__init__.py:docstring of
#: spack.environment:349
msgid "Version 5"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/environment/__init__.py:docstring of
#: spack.environment:351
msgid ""
"Version 5 doesn't change the top-level lockfile format, but an optional "
"dictionary is added. The dictionary has the ``root`` and ``concrete_specs`` "
"of the included environments, which are keyed by the path to that "
"environment. Since this is optional if the environment does not have any "
"included environments ``include_concrete`` will not be a part of the "
"lockfile."
msgstr ""

