#: spack.environment:15
msgid "``file-type``: always ``\"spack-lockfile\"``"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/environment/__init__.py:docstring of
#: spack.environment:16
msgid ""
"``lockfile-version``: an integer representing the lockfile format version"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/environment/__init__.py:docstring of
#: spack.environment:17
msgid ""
"``specfile-version``: an integer representing the spec format version (since "
"``v0.17``)"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/environment/__init__.py:docstring of
#: spack.environment:20
msgid "``spack`` (object): optional, this identifies information about Spack"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/environment/__init__.py:docstring of
#: spack.environment:21
msgid ""
"used to concretize the environment: * ``type``: required, identifies form "
"Spack version took (e.g., ``git``, ``release``) * ``commit``: the commit if "
"the version is from git * ``version``: the Spack version"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/environment/__init__.py:docstring of
#: spack.environment:26
msgid ""
"``roots`` (list): an ordered list of records representing the roots of the "
"Spack"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/environment/__init__.py:docstring of
#: spack.environment:27
msgid ""
"environment. Each has two fields: * ``hash``: a Spack spec hash uniquely "
"identifying the concrete root spec * ``spec``: a string representation of "
"the abstract spec that was concretized"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/environment/__init__.py:docstring of
#: spack.environment:31
msgid ""
"``concrete_specs``: a dictionary containing the specs in the environment."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/environment/__init__.py:docstring of
#: spack.environment:32
msgid ""
"``include_concrete`` (dictionary): an optional dictionary that includes the "
"roots and concrete specs from the included environments, keyed by the path "
"to that environment"
msgstr ""

