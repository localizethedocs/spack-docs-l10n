"            \"dependencies\": [\n"
"                {\n"
"                    \"name\": \"depname_1\",\n"
"                    \"hash\": \"<dag_hash for depname_1>\",\n"
"                    \"type\": [\"build\", \"link\"]\n"
"                },\n"
"                {\n"
"                    \"name\": \"depname_2\",\n"
"                    \"hash\": \"<dag_hash for depname_2>\",\n"
"                    \"type\": [\"build\", \"link\"]\n"
