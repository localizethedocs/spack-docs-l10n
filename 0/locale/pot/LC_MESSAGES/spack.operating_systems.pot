#: ../../../_spack_root/lib/spack/spack/operating_systems/linux_distro.py:docstring
#: of spack.operating_systems.linux_distro.LinuxDistro:1
msgid ""
"This class will represent the autodetected operating system for a Linux "
"System. Since there are many different flavors of Linux, this class will "
"attempt to encompass them all through autodetection using the python module "
"platform and the method platform.dist()"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/operating_systems/mac_os.py:docstring
#: of spack.operating_systems.mac_os.MacOs:1
msgid ""
"This class represents the macOS operating system. This will be auto detected "
"using the python platform.mac_ver. The macOS platform will be represented "
"using the major version operating system name, i.e el capitan, yosemite..."
"etc."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/operating_systems/_operating_system.py:docstring
#: of spack.operating_systems._operating_system.OperatingSystem:1
msgid "Bases: :py:class:`object`"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/operating_systems/_operating_system.py:docstring
#: of spack.operating_systems._operating_system.OperatingSystem:1
msgid "Base class for all the Operating Systems."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/operating_systems/_operating_system.py:docstring
#: of spack.operating_systems._operating_system.OperatingSystem:3
msgid ""
"On a multiple architecture machine, the architecture spec field can be set "
"to build a package against any target and operating system that is present "
"on the platform. On Cray platforms or any other architecture that has "
"different front and back end environments, the operating system will "
"determine the method of compiler detection."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/operating_systems/_operating_system.py:docstring
#: of spack.operating_systems._operating_system.OperatingSystem:9
msgid "There are two different types of compiler detection:"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/operating_systems/_operating_system.py:docstring
#: of spack.operating_systems._operating_system.OperatingSystem:11
msgid "Through the $PATH env variable (front-end detection)"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/operating_systems/_operating_system.py:docstring
#: of spack.operating_systems._operating_system.OperatingSystem:12
msgid "Through the module system. (back-end detection)"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/operating_systems/_operating_system.py:docstring
#: of spack.operating_systems._operating_system.OperatingSystem:14
msgid ""
"Depending on which operating system is specified, the compiler will be "
"detected using one of those methods."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/operating_systems/_operating_system.py:docstring
#: of spack.operating_systems._operating_system.OperatingSystem:17
msgid ""
"For platforms such as linux and darwin, the operating system is autodetected."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/operating_systems/windows_os.py:docstring
#: of spack.operating_systems.windows_os.WindowsOs:1
msgid ""
"This class represents the Windows operating system.  This will be auto "
"detected using the python platform.win32_ver() once we have a python setup "
"that runs natively.  The Windows platform will be represented using the "
"major version operating system number, e.g. 10."
msgstr ""

