#: ../../../_spack_root/lib/spack/spack/operating_systems/linux_distro.py:docstring
#: of spack.operating_systems.linux_distro.kernel_version:1
msgid ""
"Return the kernel version as a Version object. Note that the kernel version "
"is distinct from OS and/or distribution versions. For instance: >>> distro."
"id() 'centos' >>> distro.version() '7' >>> platform.release() '5.10.84+'"
msgstr ""

