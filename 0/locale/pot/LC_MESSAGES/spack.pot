msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives_meta.py:docstring of
#: spack.directives_meta.DirectiveMeta:1
msgid ""
"Flushes the directives that were temporarily stored in the staging area into "
"the package."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives_meta.py:docstring of
#: spack.directives_meta.DirectiveMeta.directive:1
msgid "Decorator for Spack directives."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives_meta.py:docstring of
#: spack.directives_meta.DirectiveMeta.directive:3
msgid ""
"Spack directives allow you to modify a package while it is being defined, e."
"g. to add version or dependency information.  Directives are one of the key "
"pieces of Spack's package \"language\", which is embedded in python."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives_meta.py:docstring of
#: spack.directives_meta.DirectiveMeta.directive:8
msgid "Here's an example directive:"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives_meta.py:docstring of
#: spack.directives_meta.DirectiveMeta.directive:10
msgid ""
"@directive(dicts='versions')\n"
"version(pkg, ...):\n"
"    ..."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives_meta.py:docstring of
#: spack.directives_meta.DirectiveMeta.directive:16
msgid "This directive allows you write:"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives_meta.py:docstring of
#: spack.directives_meta.DirectiveMeta.directive:18
msgid ""
"class Foo(Package):\n"
"    version(...)"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives_meta.py:docstring of
#: spack.directives_meta.DirectiveMeta.directive:23
msgid "The ``@directive`` decorator handles a couple things for you:"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives_meta.py:docstring of
#: spack.directives_meta.DirectiveMeta.directive:25
msgid ""
"Adds the class scope (pkg) as an initial parameter when called, like a class "
"method would.  This allows you to modify a package from within a directive, "
"while the package is still being defined."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives_meta.py:docstring of
#: spack.directives_meta.DirectiveMeta.directive:30
msgid ""
"It automatically adds a dictionary called \"versions\" to the package so "
"that you can refer to pkg.versions."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives_meta.py:docstring of
#: spack.directives_meta.DirectiveMeta.directive:33
msgid ""
"The ``(dicts='versions')`` part ensures that ALL packages in Spack will have "
"a ``versions`` attribute after they're constructed, and that if no directive "
"actually modified it, it will just be an empty dict."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives_meta.py:docstring of
#: spack.directives_meta.DirectiveMeta.directive:38
msgid ""
"This is just a modular way to add storage attributes to the Package class, "
"and it's how Spack gets information from the packages to the core."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives_meta.py:docstring of
#: spack.directives_meta.DirectiveMeta.pop_default_args:1
msgid "Pop default arguments"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives_meta.py:docstring of
#: spack.directives_meta.DirectiveMeta.pop_from_context:1
msgid "Pop the last constraint from the context"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives_meta.py:docstring of
#: spack.directives_meta.DirectiveMeta.push_default_args:1
msgid "Push default arguments"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives_meta.py:docstring of
#: spack.directives_meta.DirectiveMeta.push_to_context:1
msgid "Add a spec to the context constraints."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.can_splice:1
msgid ""
"Packages can declare whether they are ABI-compatible with another package "
"and thus can be spliced into concrete versions of that package."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.can_splice:4
msgid "The spec that the current package is ABI-compatible with."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.can_splice:5
msgid ""
"An anonymous spec constraining current package for when it is ABI-compatible "
"with target."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.can_splice:7
msgid ""
"A list of variants that must match between target spec and current package, "
"with special value '*' which matches all variants. Example: a variant is "
"defined on both packages called json, and they are ABI-compatible whenever "
"they agree on the json variant (regardless of whether it is turned on or "
"off).  Note that this cannot be applied to multi-valued variants and multi-"
"valued variants will be skipped by '*'."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.conditional:1
msgid "Conditional values that can be used in variant declarations."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.conflicts:1
msgid "Allows a package to define a conflict."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.conflicts:3
msgid ""
"Currently, a \"conflict\" is a concretized configuration that is known to be "
"non-valid. For example, a package that is known not to be buildable with "
"intel compilers can declare::"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.conflicts:7
msgid "conflicts('%intel')"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.conflicts:9
msgid ""
"To express the same constraint only when the 'foo' variant is activated::"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.conflicts:12
msgid "conflicts('%intel', when='+foo')"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.conflicts:14
msgid "constraint defining the known conflict"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.conflicts:16
msgid "optional constraint that triggers the conflict"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.conflicts:18 spack.directives.requires:14
msgid "optional user defined message"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.depends_on:1
msgid "Creates a dict of deps with specs defining when they apply."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.depends_on:3
msgid "the package and constraints depended on"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.depends_on:4
msgid ""
"when the dependent satisfies this, it has the dependency represented by "
"``spec``"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.depends_on:6
msgid "str or tuple of legal Spack deptypes"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.depends_on:7
msgid ""
"single result of ``patch()`` directive, a ``str`` to be passed to ``patch``, "
"or a list of these"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.depends_on:10
msgid ""
"This directive is to be used inside a Package definition to declare that the "
"package requires other packages to be built first. @see The section "
"\"Dependency specs\" in the Spack Packaging Guide."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.extends:1
msgid ""
"Same as depends_on, but also adds this package to the extendee list. In case "
"of Python, also adds a dependency on python-venv."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.extends:4
msgid ""
"keyword arguments can be passed to extends() so that extension packages can "
"pass parameters to the extendee's extension mechanism."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.license:1
msgid ""
"Add a new license directive, to specify the SPDX identifier the software is "
"distributed under."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.license:4
msgid ""
"SPDX identifier specifying the license(s) the software is distributed under."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.license:6
msgid ""
"string or list of strings indicating which github user checked the license "
"(if any)."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.license:8
msgid "A spec specifying when the license applies."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.maintainers:1
msgid ""
"Add a new maintainer directive, to specify maintainers in a declarative way."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.maintainers:3
msgid "GitHub username for the maintainer"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.patch:1
msgid ""
"Packages can declare patches to apply to source.  You can optionally provide "
"a when spec to indicate that a particular patch should only be applied when "
"the package's spec meets certain conditions (e.g. a particular version)."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.patch:6
msgid "url or relative filename of the patch"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.patch:7
msgid "patch level (as in the patch shell command)"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.patch:8
msgid "optional anonymous spec that specifies when to apply the patch"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.patch:9
msgid "dir to change to before applying"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.patch:10
#: ../../../_spack_root/lib/spack/spack/patch.py:docstring
#: spack.patch.apply_patch:7
msgid "reverse the patch"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.patch:11
msgid ""
"sha256 sum of the patch, used to verify the patch (only required for URL "
"patches)"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.patch:12
msgid ""
"sha256 sum of the *archive*, if the patch is compressed (only required for "
"compressed URL patches)"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.provides:1
msgid "Allows packages to provide a virtual dependency."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.provides:3
msgid ""
"If a package provides \"mpi\", other packages can declare that they depend "
"on \"mpi\", and spack can use the providing package to satisfy the "
"dependency."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.provides:6
msgid "virtual specs provided by this package"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.provides:7
msgid "condition when this provides clause needs to be considered"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.redistribute:1
msgid ""
"Can be used inside a Package definition to declare that the package source "
"and/or compiled binaries should not be redistributed."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.redistribute:5
msgid ""
"By default, Packages allow source/binary distribution (i.e. in mirrors). "
"Because of this, and because overlapping enable/ disable specs are not "
"allowed, this directive only allows users to explicitly disable "
"redistribution for specs."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.requires:1
msgid ""
"Allows a package to request a configuration to be present in all valid "
"solutions."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.requires:3
msgid ""
"For instance, a package that is known to compile only with GCC can declare:"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.requires:5
msgid "requires(\"%gcc\")"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.requires:7
msgid "A package that requires Apple-Clang on Darwin can declare instead:"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.requires:9
msgid ""
"requires(\"%apple-clang\", when=\"platform=darwin\", msg=\"Apple Clang is "
"required on Darwin\")"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.requires:11
msgid "spec expressing the requirement"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.requires:12
msgid ""
"optional constraint that triggers the requirement. If None the requirement "
"is applied unconditionally."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.resource:1
msgid ""
"Define an external resource to be fetched and staged when building the "
"package. Based on the keywords present in the dictionary the appropriate "
"FetchStrategy will be used for the resource. Resources are fetched and "
"staged in their own folder inside spack stage area, and then moved into the "
"stage area of the package that needs them."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.resource:7
msgid "List of recognized keywords:"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.resource:9
msgid ""
"'when' : (optional) represents the condition upon which the resource is "
"needed"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.resource:11
msgid ""
"'destination' : (optional) path where to move the resource. This path must "
"be relative to the main package stage area."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.resource:13
msgid ""
"'placement' : (optional) gives the possibility to fine tune how the resource "
"is moved into the main package stage area."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.variant:1
msgid "Define a variant for the package."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.variant:3
msgid "Packager can specify a default value as well as a text description."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.variant:5
msgid "Name of the variant"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.variant:6
msgid ""
"Default value for the variant, if not specified otherwise the default will "
"be False for a boolean variant and 'nothing' for a multi-valued variant"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.variant:8
msgid "Description of the purpose of the variant"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.variant:9
msgid ""
"Either a tuple of strings containing the allowed values, or a callable "
"accepting one value and returning True if it is valid"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.variant:11
msgid "If False only one value per spec is allowed for this variant"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.variant:12
msgid ""
"Optional group validator to enforce additional logic. It receives the "
"package name, the variant name and a tuple of values and should raise an "
"instance of SpackError if the group doesn't meet the additional constraints"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.variant:15
msgid "Optional condition on which the variant applies"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.variant:16
msgid ""
"The variant should not be changed by the concretizer to find a valid "
"concrete spec"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.variant:18
msgid "If arguments passed to the directive are invalid"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.version:1
msgid "Adds a version and, if appropriate, metadata for fetching its code."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.version:3
msgid ""
"The ``version`` directives are aggregated into a ``versions`` dictionary "
"attribute with ``Version`` keys and metadata values, where the metadata is "
"stored as a dictionary of ``kwargs``."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directives.py:docstring of
#: spack.directives.version:7
msgid ""
"The (keyword) arguments are turned into a valid fetch strategy for code "
"packages later. See ``spack.fetch_strategy.for_package_version()``."
msgstr ""

#: ../../../spack.rst:157
msgid "spack.directives\\_meta module"
msgstr ""

#: ../../../docstring of spack.directives_meta.directive_names:1
msgid ""
"Names of possible directives. This list is mostly populated using the "
"@directive decorator. Some directives leverage others and in that case are "
"not automatically added."
msgstr ""

#: ../../../spack.rst:165
msgid "spack.directory\\_layout module"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directory_layout.py:docstring of
#: spack.directory_layout.DirectoryLayout:1
msgid ""
"A directory layout is used to associate unique paths with specs. Different "
"installations are going to want different layouts for their install, and "
"they can use this to customize the nesting structure of spack installs. The "
"default layout is:"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directory_layout.py:docstring of
#: spack.directory_layout.DirectoryLayout:6
msgid "<install root>/"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directory_layout.py:docstring of
#: spack.directory_layout.DirectoryLayout:8
msgid "<platform-os-target>/"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directory_layout.py:docstring of
#: spack.directory_layout.DirectoryLayout:10
msgid "<compiler>-<compiler version>/"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directory_layout.py:docstring of
#: spack.directory_layout.DirectoryLayout:12
msgid "<name>-<version>-<hash>"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directory_layout.py:docstring of
#: spack.directory_layout.DirectoryLayout:14
msgid "The hash here is a SHA-1 hash for the full DAG plus the build spec."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directory_layout.py:docstring of
#: spack.directory_layout.DirectoryLayout:17
msgid ""
"The installation directory projections can be modified with the projections "
"argument."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directory_layout.py:docstring of
#: spack.directory_layout.DirectoryLayout.all_specs:1
msgid ""
"Returns a list of all specs detected in self.root, detected by `.spack` "
"directories. Their prefix is set to the directory containing the `.spack` "
"directory. Note that these specs may follow a different layout than the "
"current layout if it was changed after installation."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directory_layout.py:docstring of
#: spack.directory_layout.DirectoryLayout.deprecated_file_path:1
msgid "Gets full path to spec file for deprecated spec"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directory_layout.py:docstring of
#: spack.directory_layout.DirectoryLayout.deprecated_file_path:3
msgid ""
"If the deprecator_spec is provided, use that. Otherwise, assume "
"deprecated_spec is already deprecated and its prefix links to the prefix of "
"its deprecator."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directory_layout.py:docstring of
#: spack.directory_layout.DirectoryLayout.deprecated_for:1
msgid ""
"Returns a list of tuples of specs (new, old) where new is deprecated for old"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directory_layout.py:docstring of
#: spack.directory_layout.DirectoryLayout.ensure_installed:1
msgid ""
"Throws InconsistentInstallDirectoryError if: 1. spec prefix does not exist "
"2. spec prefix does not contain a spec file, or 3. We read a spec with the "
"wrong DAG hash out of an existing install directory."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directory_layout.py:docstring of
#: spack.directory_layout.DirectoryLayout.path_for_spec:1
msgid "Return absolute path from the root to a directory for the spec."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directory_layout.py:docstring of
#: spack.directory_layout.DirectoryLayout.read_spec:1
msgid "Read the contents of a file and parse them as a spec"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directory_layout.py:docstring of
#: spack.directory_layout.DirectoryLayout.remove_install_directory:1
msgid ""
"Removes a prefix and any empty parent directories from the root. Raised "
"RemoveFailedError if something goes wrong."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directory_layout.py:docstring of
#: spack.directory_layout.DirectoryLayout.spec_file_path:1
msgid "Gets full path to spec file"
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directory_layout.py:docstring of
#: spack.directory_layout.DirectoryLayout.write_host_environment:1
msgid ""
"The host environment is a json file with os, kernel, and spack versioning. "
"We use it in the case that an analysis later needs to easily access this "
"information."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directory_layout.py:docstring of
#: spack.directory_layout.DirectoryLayout.write_spec:1
msgid "Write a spec out to a file."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directory_layout.py:docstring of
#: spack.directory_layout.DirectoryLayoutError:1
msgid "Superclass for directory layout errors."
msgstr ""

#: ../../../_spack_root/lib/spack/spack/directory_layout.py:docstring of
#: spack.directory_layout.ExtensionAlreadyInstalledError:1
#: spack.directory_layout.ExtensionConflictError:1
#: spack.directory_layout.InconsistentInstallDirectoryError:1
