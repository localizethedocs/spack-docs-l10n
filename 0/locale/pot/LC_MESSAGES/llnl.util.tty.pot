#: ../../../_spack_root/lib/spack/llnl/util/tty/pty.py:docstring of
#: llnl.util.tty.pty.PseudoShell:1
msgid "Sets up controller and minion processes with a PTY."
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/tty/pty.py:docstring of
#: llnl.util.tty.pty.PseudoShell:3
msgid ""
"You can create a ``PseudoShell`` if you want to test how some function "
"responds to terminal input.  This is a pseudo-shell from a job control "
"perspective; ``controller_function`` and ``minion_function`` are set up with "
"a pseudoterminal (pty) so that the controller can drive the minion through "
"process control signals and I/O."
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/tty/pty.py:docstring of
#: llnl.util.tty.pty.PseudoShell:9
msgid "The two functions should have signatures like this::"
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/tty/pty.py:docstring of
#: llnl.util.tty.pty.PseudoShell:11
msgid ""
"def controller_function(proc, ctl, **kwargs)\n"
"def minion_function(**kwargs)"
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/tty/pty.py:docstring of
#: llnl.util.tty.pty.PseudoShell:14
msgid ""
"``controller_function`` is spawned in its own process and passed three "
"arguments:"
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/tty/pty.py:docstring of
#: llnl.util.tty.pty.PseudoShell:17
msgid "proc"
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/tty/pty.py:docstring of
#: llnl.util.tty.pty.PseudoShell:18
msgid "the ``multiprocessing.Process`` object representing the minion"
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/tty/pty.py:docstring of
#: llnl.util.tty.pty.PseudoShell:19
msgid "ctl"
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/tty/pty.py:docstring of
#: llnl.util.tty.pty.PseudoShell:20
msgid "a ``ProcessController`` object tied to the minion"
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/tty/pty.py:docstring of
#: llnl.util.tty.pty.PseudoShell:21
msgid "kwargs"
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/tty/pty.py:docstring of
#: llnl.util.tty.pty.PseudoShell:22
msgid "keyword arguments passed from ``PseudoShell.start()``."
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/tty/pty.py:docstring of
#: llnl.util.tty.pty.PseudoShell:24
msgid ""
"``minion_function`` is only passed ``kwargs`` delegated from ``PseudoShell."
"start()``."
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/tty/pty.py:docstring of
#: llnl.util.tty.pty.PseudoShell:27
msgid ""
"The ``ctl.controller_fd`` will have its ``controller_fd`` connected to ``sys."
"stdin`` in the minion process. Both processes will share the same ``sys."
"stdout`` and ``sys.stderr`` as the process instantiating ``PseudoShell``."
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/tty/pty.py:docstring of
#: llnl.util.tty.pty.PseudoShell:32
msgid "Here are the relationships between processes created::"
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/tty/pty.py:docstring of
#: llnl.util.tty.pty.PseudoShell:34
msgid ""
"._________________________________________________________.\n"
"| Minion Process                                          | pid     2\n"
"| - runs minion_function                                  | pgroup  2\n"
"|_________________________________________________________| session 1\n"
"    ^\n"
"    | create process with controller_fd connected to stdin\n"
"    | stdout, stderr are the same as caller\n"
"._________________________________________________________.\n"
"| Controller Process                                      | pid     1\n"
"| - runs controller_function                              | pgroup  1\n"
"| - uses ProcessController and controller_fd to           | session 1\n"
"|   control minion                                        |\n"
"|_________________________________________________________|\n"
"    ^\n"
"    | create process\n"
"    | stdin, stdout, stderr are the same as caller\n"
"._________________________________________________________.\n"
"| Caller                                                  |  pid     0\n"
"| - Constructs, starts, joins PseudoShell                 |  pgroup  0\n"
"| - provides controller_function, minion_function         |  session 0\n"
"|_________________________________________________________|"
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/tty/pty.py:docstring of
#: llnl.util.tty.pty.PseudoShell.join:1
msgid "Wait for the minion process to finish, and return its exit code."
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/tty/pty.py:docstring of
#: llnl.util.tty.pty.PseudoShell.start:1
msgid "Start the controller and minion processes."
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/tty/pty.py:docstring of
#: llnl.util.tty.pty.PseudoShell.start:3
msgid ""
"arbitrary keyword arguments that will be passed to controller and minion "
"functions"
msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/tty/pty.py:docstring of
#: llnl.util.tty.pty.PseudoShell.start:7
msgid ""
"The controller process will create the minion, then call "
"``controller_function``.  The minion process will call ``minion_function``."
msgstr ""
