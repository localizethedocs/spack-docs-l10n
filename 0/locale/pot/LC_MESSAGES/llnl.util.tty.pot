msgstr ""

#: ../../../_spack_root/lib/spack/llnl/util/tty/colify.py:docstring of
#: llnl.util.tty.colify.colify:12
msgid ""
"Force number of columns. Default is to size to terminal, or single-column if "
"no tty"
msgstr ""

